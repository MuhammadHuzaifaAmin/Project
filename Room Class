 public void allocateRoom(){
     for(int i = 0;i < totalRooms; i++){
       if (!status.get(i)){
           issuedRoomNumber = roomNumber.get(i);
           updateAllocateRoom(i);
           updateStatus(i);
           issuedRooms++;
           availableRooms--;
          // l4.setText("Room allocated successfully");
           return;
       }

       }
