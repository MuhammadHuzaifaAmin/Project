   public void addRoom(int roomnumber,int roomcapacity) throws ClassNotFoundException {
        if(roomnumber > 0 || roomcapacity > 0) {
            this.roomNumber.add(roomnumber);
            this.roomCapacity.add(roomcapacity);
            allotedRoom.add(0);
            totalRooms += 1;
            availableRooms += 1;
            status.add(false);
            Connection conn = null;
            try{
                String url = "jdbc:sqlite:Room.db";
                conn = DriverManager.getConnection(url);
            // Create your tables if they don't exist
            Statement stmt = conn.createStatement();
            stmt.execute("CREATE TABLE IF NOT EXISTS rooms (ID INTEGER PRIMARY KEY NOT NULL UNIQUE, HostelName VARCHAR(80), TotalRooms INTEGER, IssuedRooms INTEGER, AllotedRooms INTEGER, AvailableRooms INTEGER ,Status BOOLEAN,RoomNumber INTEGER NOT NULL, Capacity INTEGER NOT NULL)");
                String insertSQL = "INSERT INTO Rooms (RoomNumber, Capacity, AllotedRooms, Status) VALUES (?, ?, ?, ?)";

                PreparedStatement pstmt = conn.prepareStatement(insertSQL);
                pstmt.setInt(1, roomnumber);      // RoomNumber
                pstmt.setInt(2, roomcapacity);    // Capacity
                pstmt.setInt(3, 0);               // AllotedRooms
                pstmt.setBoolean(4, false);       // Status
                pstmt.executeUpdate();
            }catch(SQLException e){
                System.out.println("Error: " + e.getMessage());
